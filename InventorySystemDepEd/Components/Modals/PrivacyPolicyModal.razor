@* Modal for Privacy Policy *@

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.3s ease;
    }

    .modal-content {
        background: white;
        border-radius: 8px;
        max-width: 600px;
        width: 85%;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        animation: slideUp 0.3s ease;
    }

    .modal-header {
        padding: 1rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-title {
        font-size: 1rem;
        font-weight: 700;
        color: rgb(5, 39, 103);
        margin: 0;
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        color: #9ca3af;
        padding: 0;
        width: 1.5rem;
        height: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .modal-close:hover {
        color: rgb(5, 39, 103);
        background-color: #f3f4f6;
        border-radius: 4px;
    }

    .modal-body {
        padding: 1rem;
        font-size: 0.75rem;
        color: #4b5563;
        line-height: 1.5;
    }

    .modal-body h3 {
        font-size: 0.85rem;
        font-weight: 700;
        color: rgb(5, 39, 103);
        margin: 0.75rem 0 0.4rem 0;
    }

    .modal-body h3:first-child {
        margin-top: 0;
    }

    .modal-body p {
        margin: 0.4rem 0;
    }

    .modal-body ul {
        margin: 0.4rem 0 0.4rem 1rem;
        padding-left: 0;
    }

    .modal-body li {
        margin: 0.25rem 0;
    }

    .modal-footer {
        padding: 0.75rem 1rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
    }

    .modal-btn {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        border: none;
        font-size: 0.7rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .modal-btn-primary {
        background: rgb(5, 39, 103);
        color: white;
    }

    .modal-btn-primary:hover {
        background: rgb(3, 30, 80);
        box-shadow: 0 4px 12px rgba(5, 39, 103, 0.25);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="OnOverlayClick">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">Privacy Policy</h2>
                <button class="modal-close" @onclick="Close" aria-label="Close modal">
                    ✕
                </button>
            </div>

            <div class="modal-body">
                <h3>1. Introduction</h3>
                <p>
                    The DepEd ICT Equipment Inventory System ("we", "us", "our", or "System") is committed to protecting your privacy.
                    This Privacy Policy explains our data handling practices and your privacy rights when using our System.
                </p>

                <h3>Information We Collect</h3>
                <p>We collect the following types of information:</p>
                <ul>
                    <li><strong>Personal Information:</strong> Name, email address, contact number, position, and department information.</li>
                    <li><strong>Usage Data:</strong> Information about how you interact with the System, including access times, pages viewed, and actions performed.</li>
                    <li><strong>Device Information:</strong> Device type, browser, and IP address.</li>
                </ul>

                <h3>How We Use Your Information</h3>
                <p>We use the collected information for the following purposes:</p>
                <ul>
                    <li>To manage and authenticate user accounts;</li>
                    <li>To track and manage ICT equipment inventory;</li>
                    <li>To generate reports and statistics;</li>
                    <li>To improve the System and user experience;</li>
                    <li>To comply with legal obligations;</li>
                    <li>To communicate important updates and notifications.</li>
                </ul>

                <h3>Data Security</h3>
                <p>
                    We implement appropriate technical and organizational measures to protect your personal information against unauthorized access,
                    alteration, disclosure, or destruction. These measures include:
                </p>
                <ul>
                    <li>Secure password authentication and storage;</li>
                    <li>Encryption of sensitive data in transit and at rest;</li>
                    <li>Regular security audits and assessments;</li>
                    <li>Restricted access to personal information on a need-to-know basis.</li>
                </ul>

                <h3>Data Retention</h3>
                <p>
                    We retain your personal information for as long as necessary to fulfill the purposes for which it was collected,
                    or as required by law. Once you no longer need the System or upon request, your data will be securely deleted or anonymized.
                </p>

                <h3>Sharing of Information</h3>
                <p>
                    Your personal information will not be shared with third parties without your explicit consent, except when required by law
                    or for System administration purposes within the DepEd organization.
                </p>

                <h3>Your Rights</h3>
                <p>You have the right to:</p>
                <ul>
                    <li>Access your personal information;</li>
                    <li>Request correction of inaccurate data;</li>
                    <li>Request deletion of your data;</li>
                    <li>Withdraw consent at any time;</li>
                    <li>File a complaint with the appropriate data protection authority.</li>
                </ul>

                <h3>Policy Changes</h3>
                <p>
                    We may update this Privacy Policy from time to time. We will notify you of any changes by posting the updated policy
                    on the System. Continued use of the System constitutes your acceptance of the updated Privacy Policy.
                </p>

                <h3>Contact Us</h3>
                <p>
                    If you have questions about this Privacy Policy or our privacy practices, please contact the DepEd ICT Department.
                </p>
            </div>

            <div class="modal-footer">
                <button class="modal-btn modal-btn-primary" @onclick="Close">
                    Close
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private async Task OnOverlayClick()
    {
        await Close();
    }
}
