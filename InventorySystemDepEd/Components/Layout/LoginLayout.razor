@inherits LayoutComponentBase

<style>
    /* Body and overall container */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html, body {
        width: 100%;
        height: 100%;
        background: #e8eef7;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
    }

    /* Full screen login layout - SCROLLABLE */
    .login-layout {
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #e8eef7;
        padding: 1rem 0.75rem;
        overflow-y: auto;
        gap: 0.75rem;
    }

        .login-layout::-webkit-scrollbar {
            width: 6px;
        }

        .login-layout::-webkit-scrollbar-track {
            background: transparent;
        }

        .login-layout::-webkit-scrollbar-thumb {
            background: rgb(5, 39, 103);
            border-radius: 3px;
        }

            .login-layout::-webkit-scrollbar-thumb:hover {
                background: rgb(3, 30, 80);
            }

    /* Form card - NO WRAPPER, LET THE CARD SHINE */
    .login-card-wrapper {
        width: 100%;
        max-width: none;
        background: transparent;
        border-radius: 0;
        padding: 0;
        box-shadow: none;
    }

    /* Footer - ALWAYS VISIBLE */
    .login-footer {
        text-align: center;
        color: #6b7280;
        font-size: 0.65rem;
        line-height: 1.5;
        font-style: italic;
        font-family: 'Georgia', 'Times New Roman', serif;
        max-width: 480px;
        padding: 0 1rem;
    }

    /* Responsive */
    @@media (max-width: 920px) {
        .login-layout {
            padding: 1rem 1rem;
        }
    }

    @@media (max-width: 768px) {
        .login-layout {
            padding: 1.5rem 1rem;
            justify-content: center;
        }

        .login-card-wrapper {
            max-width: 100%;
        }

        .login-footer {
            max-width: 90%;
            font-size: 0.6rem;
        }
    }

    @@media (max-width: 576px) {
        .login-layout {
            padding: 1rem 0.75rem;
            padding-top: 1.5rem;
        }

        .login-footer {
            font-size: 0.55rem;
            padding: 0 0.75rem;
        }
    }
</style>

<!-- Full login layout - SCROLLABLE -->
<div class="login-layout">
    <!-- Form Card - COMPACT -->
    <div class="login-card-wrapper">
        @Body
    </div>

    <!-- Footer - VISIBLE -->
    <div class="login-footer">
        © 2026 Department of Education · Division of Lapu-Lapu City<br />
        Republic of the Philippines · All Rights Reserved
    </div>
</div>