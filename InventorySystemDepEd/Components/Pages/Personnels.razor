    // ================= SAVE (CRUD FIXED) =================
    private async Task SavePersonnel()
    {
        if (isSaving) return;

        try
        {
            isSaving = true;

            // Sync selected values to personnel object
            editingPersonnel.PositionId = selectedPositionId;
            editingPersonnel.OfficeId = selectedOfficeId;

            HttpResponseMessage response;

            if (editingPersonnel.PersonnelId == 0)
            {
                response = await Http.PostAsJsonAsync("api/personnels", editingPersonnel);
            }
            else
            {
                response = await Http.PutAsJsonAsync(
                    $"api/personnels/{editingPersonnel.PersonnelId}",
                    editingPersonnel);
            }

            if (response.IsSuccessStatusCode)
            {
                await LoadPersonnels();
                CloseCreateModal();
                ShowMessage("Personnel saved successfully.");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ShowMessage($"Failed: {error}");
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"Error: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    // ================= DELETE =================
    private void ConfirmDeletePersonnel(PersonnelDto personnel)
    {
        deletingPersonnel = personnel;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        deletingPersonnel = null;
        showDeleteModal = false;
    }

    private async Task DeletePersonnelConfirmed()
    {
        if (deletingPersonnel == null) return;

        try
        {
            await Http.DeleteAsync($"api/personnels/{deletingPersonnel.PersonnelId}");
            personnels.Remove(deletingPersonnel);
            CancelDelete();
        }
        catch (Exception ex)
        {
            ShowMessage(ex.Message);
        }
    }

