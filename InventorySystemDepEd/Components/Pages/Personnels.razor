    // ================= VALIDATION =================
    private bool IsFormValid()
    {
        return !string.IsNullOrWhiteSpace(editingPersonnel.EmployeeID)
            && !string.IsNullOrWhiteSpace(editingPersonnel.FirstName)
            && !string.IsNullOrWhiteSpace(editingPersonnel.LastName)
            && editingPersonnel.PositionId != 0
            && editingPersonnel.OfficeId != 0
            && !string.IsNullOrWhiteSpace(editingPersonnel.EmailAddress)
            && editingPersonnel.HiredDate.HasValue;
    }

    private bool IsValidEmailFormat(string? email)
        => email?.EndsWith("@deped.gov.ph", StringComparison.OrdinalIgnoreCase) == true;

    // ================= DOWNLOAD TEMPLATE (BLAZOR WASM FIX) =================
    private async Task DownloadTemplate(string moduleName)
    {
        try
        {
            var endpoint = $"api/excel/template/{moduleName.ToLower()}";

            var response = await Http.GetAsync(endpoint);

            if (!response.IsSuccessStatusCode)
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                ShowMessage($"Download failed ({response.StatusCode}): {errorContent}");
                return;
            }

            var file = await response.Content.ReadAsByteArrayAsync();

            var fileName = $"{moduleName}Template.xlsx";

            // Use JS interop to trigger browser download
            await JS.InvokeVoidAsync("downloadFile", file, fileName);

            ShowMessage($"{moduleName} template downloaded successfully.");
        }
        catch (Exception ex)
        {
            ShowMessage($"Failed to download {moduleName} template: {ex.Message}");
        }
    }

    private async Task UploadFile(InputFileChangeEventArgs e)
    {
        if (e.File == null)
        {
            ShowMessage("Please select a file.");
            return;
        }

        if (!e.File.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            ShowMessage("Only .xlsx files are supported.");
            return;
        }

        const long maxFileSize = 5 * 1024 * 1024;

        if (e.File.Size > maxFileSize)
        {
            ShowMessage("File too large (max 5MB).");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            using var stream = e.File.OpenReadStream(maxFileSize);

            var content = new MultipartFormDataContent();

            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue(
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

            content.Add(fileContent, "file", e.File.Name);

            var response = await Http.PostAsync("api/personnels/upload", content);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                ShowMessage($"Upload failed: {error}");
                return;
            }

            // ✅ READ NEW RESPONSE TYPE
            uploadSummary = await response.Content.ReadFromJsonAsync<ExcelUploadSummary>()
    ?? new ExcelUploadSummary();

            if (uploadSummary == null)
            {
                ShowMessage("Upload completed but no data returned.");
                return;
            }

            // ✅ Refresh list (valid records already saved)
            await LoadPersonnels();

            // ✅ SHOW RESULT
            if (uploadSummary.ErrorCount > 0)
            {
                showUploadModal = true; // 🔥 trigger modal with tabs
            }
            else
            {
                ShowMessage($"✓ Success! {uploadSummary.SuccessCount} records imported.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            ShowMessage($"Error: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private RenderFragment<List<ExcelRowError>> RenderErrors(List<ExcelRowError> errors) => list => builder =>
    {
        if (list == null || !list.Any())
        {
            builder.AddContent(0, "No records found.");
            return;
        }

        int seq = 0;

        foreach (var err in list)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "border-b py-2 text-sm");

            builder.AddContent(seq++,
                $"Row {err.RowNumber} | {err.EmployeeID} | {err.FullName} → {err.Column}: {err.Message}");

            builder.CloseElement();
        }
    };

    // ================= MESSAGE =================
    private async void ShowMessage(string msg)
    {
        downloadMessage = msg;
        showDownloadSuccess = true;
        StateHasChanged();

        await Task.Delay(4000);

        showDownloadSuccess = false;
        StateHasChanged();
    }
