@page "/"
@layout LoginLayout
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using System.Security.Cryptography;
@using System.Text;

<style>
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

/* =============================================
   TWO-PANE LOGIN CARD
============================================= */

.login-card {
    display: flex;
    width: 100%;
    max-width: 750px;
    height: 500px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(5, 39, 103, 0.15);
    animation: cardFadeIn 0.6s ease-out;
}

/* ── LEFT NAVY PANE ── */
.login-left {
    width: 300px;
    flex-shrink: 0;
    background: rgb(5, 39, 103);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
}

.login-left::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    pointer-events: none;
}

.login-left::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -40px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    pointer-events: none;
}

.login-left-top {
    display: flex;
    flex-direction: column;
    align-items: center;  
    text-align: center;
    position: relative;
    z-index: 1;
}

.login-left-logo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    overflow: hidden;
}

.login-left-logo img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    border-radius: 50%;
}

.login-left-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.4;
    margin-bottom: 8px;
}

.login-left-tagline {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    margin-bottom: 12px;
    font-weight: 400;
}

.login-left-sub {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    margin-bottom: 24px;
}

.login-left-divider {
    width: 24px;
    height: 2px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    margin: 0 0 16px;
}

.login-left-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.6rem;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    font-weight: 500;
    width: fit-content;
}

.login-left-badge::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #4ade80;
    flex-shrink: 0;
}

.login-left-footer {
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.6rem;
    line-height: 1.7;
    position: relative;
    z-index: 1;
}

/* ── RIGHT FORM PANE ── */
.login-right {
    flex: 1;
    background: #ffffff;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.login-right-heading {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(5, 39, 103);
    margin-bottom: 8px;
    letter-spacing: -0.2px;
    line-height: 1.3;
    text-rendering: optimizeLegibility;
}

.login-right-sub {
    font-size: 0.78rem;
    color: #9ca3af;
    letter-spacing: 0.3px;
    margin-bottom: 28px;
    font-weight: 400;
}

/* ── FORM FIELDS ── */
.lf-group {
    margin-bottom: 16px;
}

.lf-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 6px;
}

.lf-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

.lf-icon {
    position: absolute;
    left: 0.75rem;
    width: 14px;
    height: 14px;
    color: rgb(5, 39, 103);
    opacity: 0.4;
    pointer-events: none;
}

.lf-input-wrap input[type="email"],
.lf-input-wrap input[type="password"],
.lf-input-wrap input[type="text"] {
    width: 100%;
    padding: 0.65rem 2.3rem 0.65rem 2.3rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    font-size: 0.82rem;
    background: #f9fafb;
    color: #111827;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.lf-input-wrap input:focus {
    outline: none;
    border-color: rgb(5, 39, 103);
    box-shadow: 0 0 0 3px rgba(5, 39, 103, 0.07);
    background: #ffffff;
}

.lf-input-wrap input::placeholder {
    color: #d1d5db;
}

.lf-input-wrap input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.lf-toggle {
    position: absolute;
    right: 0.75rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(5, 39, 103);
    opacity: 0.4;
    width: 14px;
    height: 14px;
    padding: 0;
    transition: opacity 0.2s;
}

.lf-toggle:hover:not(:disabled) { opacity: 1; }
.lf-toggle:disabled { cursor: not-allowed; }

/* ── FOOTER ROW ── */
.lf-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.72rem;
    margin: 4px 0 20px;
}

.lf-checkbox-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #6b7280;
}

.lf-checkbox-wrap input[type="checkbox"] {
    width: 13px;
    height: 13px;
    accent-color: rgb(5, 39, 103);
    cursor: pointer;
}

.lf-forgot {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: rgb(5, 39, 103);
    font-size: 0.7rem;
    font-weight: 500;
    transition: color 0.2s;
}

.lf-forgot:hover { color: rgb(3, 28, 78); text-decoration: underline; }

/* ── SIGN IN BUTTON ── */
.lf-btn {
    width: 100%;
    padding: 0.75rem;
    /* background: rgb(5, 39, 103); */
    background: rgb(5, 39, 103);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
}

.lf-btn:hover:not(:disabled) {
    background: rgb(3, 28, 78);
    box-shadow: 0 8px 24px rgba(5, 39, 103, 0.25);
    transform: translateY(-1px);
}

.lf-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

/* ── ALERT ── */
.lf-alert {
    background: #fee2e2;
    border: 1px solid #fecaca;
    border-left: 4px solid #dc2626;
    border-radius: 0 6px 6px 0;
    color: #991b1b;
    padding: 0.6rem 0.7rem;
    font-size: 0.72rem;
    margin-bottom: 0.85rem;
}

/* ── DIVIDER + SIGNUP ── */
.lf-divider {
    text-align: center;
    color: #d1d5db;
    font-size: 0.68rem;
    margin: 0.9rem 0;
    position: relative;
}

.lf-divider::before,
.lf-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 44%;
    height: 1px;
    background: #f0f0f0;
}

.lf-divider::before { left: 0; }
.lf-divider::after  { right: 0; }

.lf-signup {
    text-align: center;
    font-size: 0.72rem;
    color: #9ca3af;
}

.lf-signup a {
    color: rgb(5, 39, 103);
    font-weight: 500;
    text-decoration: none;
}

.lf-signup a:hover { text-decoration: underline; }

/* ── SPINNER ── */
.lf-spinner {
    display: inline-block;
    width: 0.8rem;
    height: 0.8rem;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 0.8s linear infinite;
    vertical-align: middle;
    margin-right: 4px;
}

@@keyframes spin { to { transform: rotate(360deg); } }

/* ── MODAL OVERLAY ── */
.lf-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.25s ease;
}

.lf-modal-overlay.show { display: flex; }

@@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}

.lf-modal {
    background: white;
    border-radius: 14px;
    border: 0.5px solid #e5e7eb;
    max-width: 380px;
    width: 90%;
    animation: slideUp 0.25s ease;
}

@@keyframes slideUp {
    from { transform: translateY(16px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
}

.lf-modal-header {
    padding: 1rem 1.25rem;
    border-bottom: 0.5px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.lf-modal-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: rgb(5, 39, 103);
}

.lf-modal-close {
    background: none;
    border: none;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    color: #9ca3af;
    transition: color 0.2s;
}

.lf-modal-close:hover { color: rgb(5, 39, 103); }

.lf-modal-body { padding: 1rem 1.25rem; }

.lf-modal-footer {
    padding: 0.75rem 1.25rem;
    border-top: 0.5px solid #e5e7eb;
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
}

.lf-modal-btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
}

.lf-modal-btn-cancel { background: #f3f4f6; color: #374151; }
.lf-modal-btn-cancel:hover { background: #e5e7eb; }

.lf-modal-btn-submit { background: rgb(5, 39, 103); color: white; }
.lf-modal-btn-submit:hover:not(:disabled) { background: rgb(3, 28, 78); }
.lf-modal-btn-submit:disabled { opacity: 0.55; cursor: not-allowed; }

.lf-modal-label {
    display: block;
    font-size: 0.62rem;
    letter-spacing: 0.6px;
    color: #6b7280;
    font-weight: 500;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
}

.lf-modal-input {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.78rem;
    background: #f9fafb;
    box-sizing: border-box;
    transition: border-color 0.2s;
    margin-bottom: 0.75rem;
}

.lf-modal-input:focus {
    outline: none;
    border-color: rgb(5, 39, 103);
    box-shadow: 0 0 0 3px rgba(5, 39, 103, 0.07);
}

.lf-modal-success {
    background: #dcfce7;
    border: 1px solid #bbf7d0;
    border-left: 4px solid #22c55e;
    border-radius: 0 6px 6px 0;
    color: #166534;
    padding: 0.6rem 0.7rem;
    font-size: 0.72rem;
    margin-bottom: 0.85rem;
}

/* ── RESPONSIVE ── */
@@media (max-width: 920px) {
    .login-card {
        max-width: 95%;
        margin: 0 auto;
    }
}

@@media (max-width: 768px) {
    .login-left { display: none; }
    .login-card { 
        max-width: 500px; 
        height: auto; 
        min-height: 520px;
        margin: 0 auto;
    }
    .login-right { padding: 2.5rem 2rem; }
}

@@media (max-width: 560px) {
    .login-card { 
        max-width: 100%; 
        height: auto; 
        min-height: auto; 
        margin: 1rem;
        border-radius: 14px;
    }
    .login-right { padding: 2rem 1.5rem; }
}
</style>

<div class="login-card">

    <!-- LEFT NAVY PANE -->
    <div class="login-left">
        <div class="login-left-top">
            <div class="login-left-logo">
                <img src="images/logo.png" alt="DepEd Logo" />
            </div>
            <div class="login-left-title">PULSE SYSTEM</div>
            <div class="login-left-tagline">Procurement & Unified Ledger for Supply & Equipment</div>
            <div class="login-left-divider" style="margin: 10px auto 12px;"></div>
            <div class="login-left-sub">Division of Lapu-Lapu City</div>
            <div style="margin-top: 1rem;">
                <span class="login-left-badge">Authorized Access Only</span>
            </div>
            @* <div class="login-left-sub" style="margin-top: 1.5rem;">
                A centralized platform for tracking and auditing school assets across the division.
            </div> *@
        </div>
        <div class="login-left-footer">
            Trusted Education Platform
        </div>
    </div>

    <!-- RIGHT FORM PANE -->
    <div class="login-right">
        <div class="login-right-heading">Welcome back</div>
        <div class="login-right-sub">Sign in to your account to continue</div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="lf-alert">@errorMessage</div>
        }

        <form @onsubmit="HandleLogin" @onsubmit:preventDefault>

            <!-- Email -->
            <div class="lf-group">
                <label class="lf-label">Email Address</label>
                <div class="lf-input-wrap">
                    <svg class="lf-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" tabindex="-1">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <input type="email"
                           placeholder="yourname@deped.gov.ph"
                           @bind="email"
                           @bind:event="oninput"
                           disabled="@isLoading"
                           required
                           @ref="emailInputRef"
                           @onkeydown="HandleMainFormKeyDown" />
                </div>
            </div>

            <!-- Password -->
            <div class="lf-group">
                <label class="lf-label">Password</label>
                <div class="lf-input-wrap">
                    <svg class="lf-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" tabindex="-1">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <input type="@passwordInputType"
                           placeholder="••••••••"
                           @bind="password"
                           @bind:event="oninput"
                           disabled="@isLoading"
                           required
                           @ref="passwordInputRef"
                           @onkeydown="HandleMainFormKeyDown" />
                    <button type="button" class="lf-toggle" @onclick="TogglePasswordVisibility" disabled="@isLoading">
                        @if (showPassword)
                        {
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" tabindex="-1">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                            </svg>
                        }
                        else
                        {
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" tabindex="-1">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <div class="lf-footer-row">
                <div class="lf-checkbox-wrap">
                    <input type="checkbox" id="remember" @bind="rememberMe" disabled="@isLoading" />
                    <label for="remember">Remember me</label>
                </div>
                <button type="button" class="lf-forgot" @onclick="OpenForgotModal">Forgot password?</button>
            </div>

            <button type="submit" class="lf-btn" disabled="@(!IsFormValid || isLoading)">
                @if (isLoading)
                {
                    <span class="lf-spinner"></span>
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>
        </form>

        <div class="lf-divider">or</div>
        <div class="lf-signup">
            New user? <a href="register">Create an Account</a>
        </div>
    </div>
</div>

<!-- Forgot Password Modal -->
<div class="lf-modal-overlay @(showForgotModal ? "show" : "")">
    <div class="lf-modal">
        <div class="lf-modal-header">
            <h2 class="lf-modal-title">Forgot Password?</h2>
            <button type="button" class="lf-modal-close" @onclick="CloseForgotModal">&times;</button>
        </div>
        <div class="lf-modal-body">
            <p style="font-size: 0.72rem; color: #6b7280; margin-bottom: 1.1rem;">
                Enter your name and email address. Your department head will be notified to reset your password.
            </p>

            @if (!string.IsNullOrEmpty(forgotSuccessMessage))
            {
                <div class="lf-modal-success">@forgotSuccessMessage</div>
            }

            <label class="lf-modal-label">Full Name</label>
            <input type="text"
                   class="lf-modal-input"
                   placeholder="Enter your full name"
                   @bind="forgotPasswordName"
                   @bind:event="oninput"
                   disabled="@forgotIsSubmitting"
                   @ref="forgotNameInputRef"
                   @onkeydown="HandleModalKeyDown" />

            <label class="lf-modal-label">Email Address</label>
            <input type="email"
                   class="lf-modal-input"
                   placeholder="yourname@deped.gov.ph"
                   @bind="forgotPasswordEmail"
                   @bind:event="oninput"
                   disabled="@forgotIsSubmitting"
                   @ref="forgotEmailInputRef"
                   @onkeydown="HandleModalKeyDown" />
        </div>
        <div class="lf-modal-footer">
            <button type="button" class="lf-modal-btn lf-modal-btn-cancel" @onclick="CloseForgotModal">Cancel</button>
            <button type="button" class="lf-modal-btn lf-modal-btn-submit" @onclick="HandleForgotPassword" disabled="@(!IsForgotFormValid || forgotIsSubmitting)">
                @if (forgotIsSubmitting)
                {
                    <span>Sending...</span>
                }
                else
                {
                    <span>Send Request</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private bool rememberMe = false;
    private bool showPassword = false;
    private string passwordInputType = "password";
    private bool isLoading = false;
    private string errorMessage = "";
    private ElementReference emailInputRef;
    private ElementReference passwordInputRef;

    private const string RememberedEmailKey = "rememberedEmail";

    private bool IsFormValid => !string.IsNullOrWhiteSpace(email) && !string.IsNullOrWhiteSpace(password);

    protected override async Task OnInitializedAsync()
    {
        await LoadRememberedEmail();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await emailInputRef.FocusAsync();
        }
    }

    private async Task LoadRememberedEmail()
    {
        try
        {
            var savedEmail = await JSRuntime.InvokeAsync<string>("localStorage.getItem", RememberedEmailKey);
            if (!string.IsNullOrEmpty(savedEmail))
            {
                email = savedEmail;
                rememberMe = true;
            }
        }
        catch { }
    }

    private async Task SaveRememberedEmail(string emailToSave)
    {
        try
        {
            if (rememberMe)
                await JSRuntime.InvokeVoidAsync("localStorage.setItem", RememberedEmailKey, emailToSave);
            else
                await JSRuntime.InvokeVoidAsync("localStorage.removeItem", RememberedEmailKey);
        }
        catch { }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
        passwordInputType = showPassword ? "text" : "password";
    }

    private async Task HandleLogin()
    {
        errorMessage = "";

        if (!IsFormValid)
        {
            errorMessage = "Please enter email and password.";
            return;
        }

        isLoading = true;

        try
        {
            var request = new InventorySystemDepEd.Shared.DTOs.Auth.LoginRequest
            {
                Email = email.Trim().ToLower(),
                Password = ComputeMD5(password.Trim())
            };

            var response = await Http.PostAsJsonAsync("api/Auth/login", request);

            var result = await response.Content
                .ReadFromJsonAsync<InventorySystemDepEd.Shared.DTOs.Auth.LoginResponse>();

            if (response.IsSuccessStatusCode && result != null && result.Success)
            {
                await SaveRememberedEmail(request.Email);

                SessionData.UserID = result.UserId;
                SessionData.UserEmail = result.Email;
                SessionData.UserFullName = result.FullName;
                SessionData.UserRole = result.Role;
                SessionData.IsLoggedIn = true;
                SessionData.CurrentUserId = result.PersonnelId;
                SessionData.CurrentOfficeId = result.OfficeId;

                Navigation.NavigateTo("/dashboard");
                return;
            }

            errorMessage = result?.Message ?? "Login failed. Please try again.";
        }
        catch (Exception ex)
        {
            errorMessage = "Login failed: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Forgot Password ──
    private bool showForgotModal = false;
    private string _forgotPasswordName = "";
    private ElementReference forgotNameInputRef;
    private ElementReference forgotEmailInputRef;

    private string forgotPasswordName
    {
        get => _forgotPasswordName;
        set
        {
            if (value != null)
            {
                string filtered = new string(value.Where(c => char.IsLetter(c) || char.IsWhiteSpace(c)).ToArray());
                if (_forgotPasswordName != filtered)
                    _forgotPasswordName = filtered;
            }
        }
    }

    private string forgotPasswordEmail = "";
    private bool forgotIsSubmitting = false;
    private string forgotSuccessMessage = "";

    private bool IsForgotFormValid =>
        !string.IsNullOrWhiteSpace(forgotPasswordName) &&
        !string.IsNullOrWhiteSpace(forgotPasswordEmail) &&
        forgotPasswordEmail.Contains("@") &&
        IsValidName(forgotPasswordName);

    private bool IsValidName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return false;
        return name.All(c => char.IsLetter(c) || char.IsWhiteSpace(c));
    }

    private void OpenForgotModal()
    {
        showForgotModal = true;
        forgotPasswordName = "";
        forgotPasswordEmail = "";
        forgotSuccessMessage = "";
        StateHasChanged();
    }

    private void CloseForgotModal()
    {
        showForgotModal = false;
        forgotPasswordName = "";
        forgotPasswordEmail = "";
        StateHasChanged();
    }

    private async Task HandleModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Tab")
        {
            await JSRuntime.InvokeVoidAsync("eval", "event.preventDefault()");
            if (e.ShiftKey)
                await forgotNameInputRef.FocusAsync();
            else
                await forgotEmailInputRef.FocusAsync();
        }
    }

    private async Task HandleMainFormKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Tab")
        {
            await JSRuntime.InvokeVoidAsync("eval", "event.preventDefault()");
            if (e.ShiftKey)
                await emailInputRef.FocusAsync();
            else
                await passwordInputRef.FocusAsync();
        }
    }

    private async Task HandleForgotPassword()
    {
        if (!IsForgotFormValid) return;

        forgotIsSubmitting = true;

        try
        {
            forgotSuccessMessage = "Request sent! Your department head will be notified.";
            StateHasChanged();

            await Task.Delay(3000);

            showForgotModal = false;
            forgotSuccessMessage = "";
            forgotPasswordName = "";
            forgotPasswordEmail = "";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            forgotSuccessMessage = $"Error: {ex.Message}";
            StateHasChanged();
            await Task.Delay(3000);
            forgotSuccessMessage = "";
            StateHasChanged();
        }
        finally
        {
            forgotIsSubmitting = false;
        }
    }

    private static string ComputeMD5(string input)
    {
        using var md5 = MD5.Create();
        var bytes = md5.ComputeHash(Encoding.UTF8.GetBytes(input));
        var sb = new StringBuilder();
        for (int i = 0; i < bytes.Length; i++)
            sb.Append(bytes[i].ToString("x2"));
        return sb.ToString();
    }
}
