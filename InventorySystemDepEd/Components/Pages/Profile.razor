@page "/Profile"
@using InventorySystemDepEd.Shared.DTOs.Profile
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Security.Cryptography
@using System.Text
@layout MainLayout

<PageTitle>User Profile</PageTitle>

@if (CurrentUser == null)
{
    <div class="flex justify-center items-center min-h-screen bg-gray-100">
        <p class="text-gray-400 text-sm">Loading profile...</p>
    </div>
}
else
{
    <div class="p-6 bg-gray-100 min-h-screen">
        <div class="max-w-6xl mx-auto flex flex-col gap-4">

            <!-- Hero -->
            <div class="rounded-xl p-8 flex items-center justify-between gap-6 flex-wrap" style="background-color: #052767;">
                <div class="flex items-center gap-6">
                    <!-- Avatar -->
                    <div class="w-20 h-20 rounded-full flex items-center justify-center text-2xl font-bold text-white flex-shrink-0"
                         style="background: rgba(255,255,255,0.13); border: 2px solid rgba(255,255,255,0.32);">
                        @GetInitials(CurrentUser?.Personnel?.FirstName ?? "", CurrentUser?.Personnel?.LastName ?? "")
                    </div>
                    <!-- Info -->
                    <div>
                        <h1 class="text-2xl font-bold text-white mb-1">
                            @CurrentUser?.Personnel?.FirstName @CurrentUser?.Personnel?.LastName
                        </h1>
                        <p class="text-sm mb-3" style="color: rgba(255,255,255,0.65);">@CurrentUser?.UserEmailAddress</p>
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium text-white"
                                  style="background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.26);">
                                <span class="bi bi-star-fill text-xs"></span>
                                @CurrentUser?.RoleName
                            </span>
                            @if (CurrentUser?.UserIsApproved ?? false)
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium"
                                      style="background: rgba(74,222,128,0.16); color: #86efac; border: 1px solid rgba(74,222,128,0.35);">
                                    <span class="bi bi-check-circle-fill text-xs"></span>
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium"
                                      style="background: rgba(248,113,113,0.16); color: #fca5a5; border: 1px solid rgba(248,113,113,0.35);">
                                    <span class="bi bi-x-circle-fill text-xs"></span>
                                    Inactive
                                </span>
                            }
                        </div>
                    </div>
                </div>
                <!-- Change Password Button -->
                <button class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg text-sm font-semibold hover:opacity-90 transition whitespace-nowrap"
                        style="color: #052767;"
                        @onclick="() => showChangePasswordModal = true">
                    <span class="bi bi-lock-fill"></span>
                    Change password
                </button>
            </div>

            <!-- Personal Information -->
            <div class="bg-white rounded-xl border border-gray-200 p-6">
                <div class="flex items-center gap-3 mb-5 pb-4 border-b border-gray-200">
                    <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0" style="color: #052767;">
                        <span class="bi bi-person-fill text-base"></span>
                    </div>
                    <h2 class="text-base font-semibold" style="color: #052767;">Personal information</h2>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Employee ID</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.EmployeeID</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">First name</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.FirstName</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Middle name</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.MiddleName</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Last name</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.LastName</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Email address</label>
                        <p class="text-sm font-medium text-gray-900 break-all">@CurrentUser?.UserEmailAddress</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Mobile number</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.ContactNumber</p>
                    </div>
                </div>
            </div>

            <!-- Organization -->
            <div class="bg-white rounded-xl border border-gray-200 p-6">
                <div class="flex items-center gap-3 mb-5 pb-4 border-b border-gray-200">
                    <div class="w-9 h-9 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0" style="color: #052767;">
                        <span class="bi bi-briefcase-fill text-base"></span>
                    </div>
                    <h2 class="text-base font-semibold" style="color: #052767;">Organization</h2>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Position</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.PositionName</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Office</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.Office?.OfficeName</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Department</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.Office?.DepartmentName</p>
                    </div>
                    <div class="flex flex-col p-4 rounded-lg bg-gray-50 border border-gray-200">
                        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Date hired</label>
                        <p class="text-sm font-medium text-gray-900">@CurrentUser?.Personnel?.HiredDate?.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
            </div>

            <!-- Back Button -->
            <div class="flex justify-end pb-2">
                <button class="inline-flex items-center gap-2 px-4 py-2 text-white text-sm font-semibold rounded-lg hover:opacity-90 transition whitespace-nowrap"
                        style="background-color: #052767;"
                        @onclick="GoBack">
                    <span class="bi bi-arrow-left text-sm"></span>
                    Back to dashboard
                </button>
            </div>

        </div>
    </div>
}

<!-- Change Password Modal -->
@if (showChangePasswordModal)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden">

            <!-- Modal Header -->
            <div class="px-6 py-4 flex items-center justify-between" style="background-color: #052767;">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(255,255,255,0.14);">
                        <span class="bi bi-lock-fill text-white text-sm"></span>
                    </div>
                    <h2 class="text-base font-semibold text-white">Change password</h2>
                </div>
                <button type="button"
                        class="w-7 h-7 rounded-lg flex items-center justify-center text-white/70 hover:text-white hover:bg-white/10 transition text-lg leading-none"
                        @onclick="() => showChangePasswordModal = false"
                        aria-label="Close">
                    &#215;
                </button>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-5 space-y-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Current password</label>
                    <input type="password"
                           class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 focus:outline-none focus:border-[#052767] transition"
                           placeholder="••••••••"
                           @bind="CurrentPassword" />
                    @if (currentPasswordError != "")
                    {
                        <p class="text-xs text-red-500 mt-0.5">@currentPasswordError</p>
                    }
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">New password</label>
                    <input type="password"
                           class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 focus:outline-none focus:border-[#052767] transition"
                           placeholder="Enter new password"
                           @bind="NewPassword" />
                    @if (newPasswordError != "")
                    {
                        <p class="text-xs text-red-500 mt-0.5">@newPasswordError</p>
                    }
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Confirm new password</label>
                    <input type="password"
                           class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-900 focus:outline-none focus:border-[#052767] transition"
                           placeholder="Confirm new password"
                           @bind="ConfirmPassword" />
                    @if (confirmPasswordError != "")
                    {
                        <p class="text-xs text-red-500 mt-0.5">@confirmPasswordError</p>
                    }
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-end gap-2">
                <button type="button"
                        class="px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition"
                        @onclick="() => showChangePasswordModal = false">
                    Cancel
                </button>
                <button type="button"
                    class="px-4 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition inline-flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
                    style="background-color: #052767;"
                    disabled="@isChangingPassword"
                    @onclick="async () => await ChangePassword()">
                @if (isChangingPassword)
                {
                    <span class="bi bi-hourglass-split text-sm animate-spin"></span>
                    <span>Processing...</span>
                }
                else
                {
                    <span>Save changes</span>
                }
            </button>
            </div>
        </div>
    </div>
}

@if (showToast)
{
    <div class="fixed top-4 z-[9999] flex justify-center pointer-events-none"
         style="left: 50%; transform: translateX(-50%);">
        <div class="px-6 py-4 rounded-lg flex items-center gap-4 pointer-events-auto animate-fade-in shadow-xl"
             style="background-color: @toastBgColor; min-width: 280px; max-width: 380px;">
            <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="@iconClassValue text-xl"></span>
            </div>
            <div class="flex-1 min-w-0">
                <p class="font-semibold text-sm text-white">@toastTitle</p>
                <p class="text-xs text-white mt-0.5">@toastMessage</p>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    .animate-fade-in {
        animation: fadeIn 0.3s ease-out;
    }

    .animate-spin {
        animation: spin 1s linear infinite;
    }
</style>

@code {
    #nullable enable

    private UserProfileDto? CurrentUser;
    private bool showChangePasswordModal = false;
    private bool isChangingPassword = false;

   // Toast 
    private bool showToast = false;
    private string toastTitle = "";
    private string toastMessage = "";
    private string iconClassValue = "";
    private string toastBgColor = "#1b5e20";

    //  use for change pass validation
    private string currentPasswordError = "";
    private string newPasswordError = "";
    private string confirmPasswordError = "";

    private string CurrentPassword = "";
    private string NewPassword = "";
    private string ConfirmPassword = "";

    protected override async Task OnInitializedAsync()
    {
        if (SessionData.UserID > 0)
        {
            CurrentUser =
            await Http.GetFromJsonAsync<UserProfileDto>(
                $"api/profile/{SessionData.UserID}");
        }
    }

    private void GoBack() => Navigation.NavigateTo("/Dashboard");

    private string GetInitials(string firstName, string lastName)
    {
        var initials = "";
        if (!string.IsNullOrWhiteSpace(firstName)) initials += firstName[0];
        if (!string.IsNullOrWhiteSpace(lastName)) initials += lastName[0];
        return initials.ToUpper();
    }

    private async Task ChangePassword()
{
    // clear errors first
    currentPasswordError = "";
    newPasswordError = "";
    confirmPasswordError = "";

    var isValid = true;

    if (string.IsNullOrWhiteSpace(CurrentPassword))
    {
        currentPasswordError = "Please enter your current password.";
        isValid = false;
    }

    if (string.IsNullOrWhiteSpace(NewPassword))
    {
        newPasswordError = "Please enter a new password.";
        isValid = false;
    }
    else if (NewPassword.Length < 8)
    {
        newPasswordError = "Password must be at least 8 characters.";
        isValid = false;
    }
    else if (!System.Text.RegularExpressions.Regex.IsMatch(NewPassword, @"[!@#$%^&*()_+\-=\[\]{};':""\\|,.<>\/?]"))
    {
        newPasswordError = "Password must contain at least one special character.";
        isValid = false;
    }

    if (string.IsNullOrWhiteSpace(ConfirmPassword))
    {
        confirmPasswordError = "Please confirm your new password.";
        isValid = false;
    }
    else if (NewPassword != ConfirmPassword)
    {
        confirmPasswordError = "Passwords do not match.";
        isValid = false;
    }

    if (!isValid) return;

    try
    {
        isChangingPassword = true;
        StateHasChanged();

        var dto = new ChangePasswordDto
        {
            UserId = SessionData.UserID,
            CurrentPassword = ComputeMD5(CurrentPassword),
            NewPassword = ComputeMD5(NewPassword)
        };

        var response = await Http.PostAsJsonAsync("api/profile/change-password", dto);

        if (response.IsSuccessStatusCode)
        {
            CurrentPassword = "";
            NewPassword = "";
            ConfirmPassword = "";
            currentPasswordError = "";
            newPasswordError = "";
            confirmPasswordError = "";

            showChangePasswordModal = false;
            StateHasChanged();

            await Task.Delay(200);
            await ShowToastAsync("Password changed", "Your password has been updated successfully.", true);
        }
        else
        {
            currentPasswordError = "Current password is incorrect.";
        }
    }
    catch
    {
        await ShowToastAsync("Error", "An error occurred while changing password", false);
    }
    finally
    {
        isChangingPassword = false;
        StateHasChanged();
    }
}

private async Task ShowToastAsync(string title, string message, bool isSuccess)
{
    toastTitle = title;
    toastMessage = message;
    toastBgColor = isSuccess ? "#1b5e20" : "#b91c1c";
    iconClassValue = isSuccess
        ? "bi bi-check-circle-fill text-white"
        : "bi bi-x-circle-fill text-white";
    showToast = true;
    StateHasChanged();
    await Task.Delay(4000);
    showToast = false;
    StateHasChanged();
}

    private static string ComputeMD5(string input)
    {
        using var md5 = MD5.Create();
        var bytes = md5.ComputeHash(Encoding.UTF8.GetBytes(input));

        var sb = new StringBuilder();
        for (int i = 0; i < bytes.Length; i++)
            sb.Append(bytes[i].ToString("x2"));

        return sb.ToString();
    }
}
