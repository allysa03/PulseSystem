@page "/OfficeDetails/{OfficeId:int}"
@layout MainLayout
@using InventorySystemDepEd.Shared.DTOs
@using InventorySystemDepEd.Shared.DTOs.Personnels
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Office Details</PageTitle>

<div class="p-6 bg-gray-50 min-h-screen">

    <!-- HEADER -->
    <div class="flex justify-between items-end pb-4 mb-5 border-b border-gray-200">
        <div>
            <h1 class="text-lg font-bold text-[rgb(5,39,103)] tracking-tight mb-0.5">Office Details</h1>
            <p class="text-xs text-gray-400">View complete information about the office</p>
        </div>
        <button class="flex items-center gap-1.5 px-5 py-2 text-xs font-medium text-gray-500 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:text-gray-700 transition"
                @onclick="GoBack">
            ← Back
        </button>
    </div>

    @if (office is null)
    {
        <div class="bg-white border border-gray-200 rounded-xl p-6 text-xs text-gray-400 shadow-sm">
            Loading office details…
        </div>
    }
    else
    {
        <!-- SUMMARY CARD -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm mb-4 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100">
                <h2 class="text-base font-bold text-gray-800 mb-1">@office.OfficeName</h2>
                <span class="inline-block text-[11px] font-semibold text-[rgb(5,39,103)] bg-[rgb(5,39,103)]/8 rounded-full px-2.5 py-0.5 tracking-wide">
                    @office.DepartmentName
                </span>
            </div>
            <div class="flex flex-wrap gap-6 px-5 py-3.5">
                <span class="text-xs text-gray-500">
                    <span class="font-semibold text-gray-700">Location</span>&nbsp; @office.Location
                </span>
                <span class="text-xs text-gray-500">
                    <span class="font-semibold text-gray-700">Contact</span>&nbsp; @office.ContactNumber
                </span>
                <span class="text-xs text-gray-500">
                    <span class="font-semibold text-gray-700">Office Head</span>&nbsp; @office.OfficeHeadName
                </span>
            </div>
        </div>

        <!-- TAB PANEL -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">

            <!-- Tab bar -->
            <div class="flex items-center bg-gray-50 border-b border-gray-100 px-2">
                @foreach (var tab in tabs)
                {
                    <button class="px-4 py-3 text-sm font-medium border-b-2 transition @(activeTab == tab.Key ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500")"
                            @onclick="() => SetActiveTab(tab.Key)">
                        @tab.Label
                        <span class="ml-1 text-xs bg-gray-200 px-2 py-0.5 rounded-full">
                            @GetTabCount(tab.Key)
                        </span>
                    </button>
                }

                <div class="ml-auto mr-3">
                    <input type="text"
                           class="border border-gray-200 rounded-lg px-3 py-1.5 text-xs text-gray-700 bg-white w-44 focus:outline-none focus:border-[rgb(5,39,103)] focus:ring-2 focus:ring-[rgb(5,39,103)]/10 placeholder-gray-300 transition"
                           placeholder="@GetPlaceholder()"
                           @bind="CurrentSearch"
                           @bind:event="oninput"
                           @onkeydown="HandleEscape" />
                </div>
            </div>

            <!-- Tab content -->
            <div class="p-5">

                @if (activeTab == "personnel")
                {
                    var filtered = personnels
                        .Where(p =>
                            string.IsNullOrWhiteSpace(personnelSearch) ||
                            (p.FullName?.Contains(personnelSearch, StringComparison.OrdinalIgnoreCase) ?? false))
                        .ToList();

                    <table class="w-full text-xs">
                        <thead class="bg-gradient-to-r from-[rgb(5,39,103)] to-[rgb(3,30,80)] text-white">
                            <tr>
                                <th class="p-3 text-left">Name</th>
                                <th class="p-3 text-left">Position</th>
                                <th class="p-3 text-left">Email</th>
                                <th class="p-3 text-left">Contact</th>
                                <th class="p-3 text-left">Hired Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filtered.Any())
                            {
                                <tr>
                                    <td colspan="5" class="p-6 text-center text-gray-500"> No Personnel Found </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var p in GetPaged(filtered, personnelPage))
                                {
                                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                                        <td class="px-4 py-2.5 text-gray-700">@p.FullName</td>
                                        <td class="px-4 py-2.5 text-gray-500">@p.PositionName</td>
                                        <td class="px-4 py-2.5 text-gray-500">@p.EmailAddress</td>
                                        <td class="px-4 py-2.5 text-gray-500">@p.ContactNumber</td>
                                        <td class="px-4 py-2.5 text-gray-500">@p.HiredDate?.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <Pagination TotalItems="@filtered.Count"
                                ItemsLabel="Total Personnel"
                                ItemsPerPage="pageSize"
                                CurrentPage="personnelPage"
                                OnPageChanged="OnPersonnelPageChanged" />
                }

                else if (activeTab == "equipment")
                {
                    var filtered = equipments
                        .Where(x =>
                            string.IsNullOrWhiteSpace(equipmentSearch) ||
                            x.Contains(equipmentSearch, StringComparison.OrdinalIgnoreCase))
                        .ToList();

                    <table class="w-full text-xs">
                        <thead class="bg-gradient-to-r from-[rgb(5,39,103)] to-[rgb(3,30,80)] text-white">
                            <tr>
                                <th class="p-3 text-left">Equipment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filtered.Any())
                            {
                                <tr>
                                    <td class="p-6 text-center text-gray-500"> No Equipment Found </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in GetPaged(filtered, equipmentPage))
                                {
                                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                                        <td class="px-4 py-2.5 text-gray-700">@item</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <Pagination TotalItems="@filtered.Count"
                                ItemsLabel="Total Equipment"
                                ItemsPerPage="pageSize"
                                CurrentPage="equipmentPage"
                                OnPageChanged="OnEquipmentPageChanged" />
                }

                else if (activeTab == "transferred")
                {
                    var filtered = transferredEmployees
                        .Where(t =>
                            (t.OriginOfficeId == OfficeId || t.DestinationOfficeId == OfficeId) &&
                            (string.IsNullOrWhiteSpace(transferredSearch) ||
                             (t.FullName?.Contains(transferredSearch, StringComparison.OrdinalIgnoreCase) ?? false)))
                        .ToList();

                    <table class="w-full text-xs">
                        <thead class="bg-gradient-to-r from-[rgb(5,39,103)] to-[rgb(3,30,80)] text-white">
                            <tr>
                                <th class="p-3 text-left">Name</th>
                                <th class="p-3 text-left">Position</th>
                                <th class="p-3 text-left">Destination</th>
                                <th class="p-3 text-left">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filtered.Any())
                            {
                                <tr>
                                    <td colspan="4" class="p-6 text-center text-gray-500"> No Transfers Found </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var t in GetPaged(filtered, transferredPage))
                                {
                                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                                        <td class="px-4 py-2.5 text-gray-700">@t.FullName</td>
                                        <td class="px-4 py-2.5 text-gray-500">@t.PositionName</td>
                                        <td class="px-4 py-2.5 text-gray-500">@t.DestinationOfficeName</td>
                                        <td class="px-4 py-2.5">
                                            @{
                                                var statusClass = t.Status?.ToLower() switch
                                                {
                                                    "pending" => "bg-yellow-50 text-yellow-700 border border-yellow-200",
                                                    "approved" => "bg-green-50 text-green-700 border border-green-200",
                                                    "rejected" => "bg-red-50 text-red-600 border border-red-200",
                                                    _ => "bg-gray-100 text-gray-600 border border-gray-200"
                                                };
                                            }
                                            <span class="inline-block text-[10px] font-semibold rounded-full px-2 py-0.5 @statusClass">
                                                @t.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <Pagination TotalItems="@filtered.Count"
                                ItemsLabel="Total Transfers"
                                ItemsPerPage="pageSize"
                                CurrentPage="transferredPage"
                                OnPageChanged="OnTransferredPageChanged" />
                }

            </div>
        </div>
    }
</div>

@code {
#nullable enable

    [Parameter] public int OfficeId { get; set; }

    private OfficeDto? office;

    private string activeTab = "personnel";
    private int pageSize = 5;

    private List<(string Key, string Label)> tabs = new()
    {
        ("personnel", "Personnel"),
        ("equipment", "Equipment"),
        ("transferred", "Transfers")
    };

    private int personnelPage = 1;
    private int equipmentPage = 1;
    private int transferredPage = 1;

    private string personnelSearch = "";
    private string equipmentSearch = "";
    private string transferredSearch = "";

    private List<PersonnelDto> personnels = new();
    private List<string> equipments = new() { "Desktop PC", "Printer", "Projector" };
    private List<TransferDto> transferredEmployees = new();

    protected override async Task OnInitializedAsync()
    {
        office = await Http.GetFromJsonAsync<OfficeDto>($"/api/offices/{OfficeId}");

        personnels = await Http.GetFromJsonAsync<List<PersonnelDto>>(
            $"api/offices/{OfficeId}/personnels"
        ) ?? new();

        transferredEmployees = await Http.GetFromJsonAsync<List<TransferDto>>(
            $"/api/offices/{OfficeId}/transfers"
        ) ?? new();
    }

    private string CurrentSearch
    {
        get => activeTab switch
        {
            "personnel" => personnelSearch,
            "equipment" => equipmentSearch,
            "transferred" => transferredSearch,
            _ => ""
        };
        set
        {
            if (activeTab == "personnel")
            {
                personnelSearch = value;
                personnelPage = 1;
            }
            else if (activeTab == "equipment")
            {
                equipmentSearch = value;
                equipmentPage = 1;
            }
            else if (activeTab == "transferred")
            {
                transferredSearch = value;
                transferredPage = 1;
            }
        }
    }

    private IEnumerable<T> GetPaged<T>(List<T> source, int page)
    {
        return source
            .Skip((page - 1) * pageSize)
            .Take(pageSize);
    }

    private void HandleEscape(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            CurrentSearch = "";
    }

    private void SetActiveTab(string tab) => activeTab = tab;

    private int GetTabCount(string key) => key switch
    {
        "personnel" => personnels.Count,
        "equipment" => equipments.Count,
        "transferred" => transferredEmployees.Count,
        _ => 0
    };

    private string GetPlaceholder() => activeTab switch
    {
        "personnel" => "Search personnel...",
        "equipment" => "Search equipment...",
        "transferred" => "Search transfers...",
        _ => ""
    };

    private void OnPersonnelPageChanged(int p) => personnelPage = p;
    private void OnEquipmentPageChanged(int p) => equipmentPage = p;
    private void OnTransferredPageChanged(int p) => transferredPage = p;

    private void GoBack() => Navigation.NavigateTo("/offices");
}
