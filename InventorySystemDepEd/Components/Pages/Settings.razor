@* @code {
    // private UISeriesFormatSetting settings = new();
    private bool showToast = false;

    private Dictionary<string, string?> previews = new();
    private List<SettingsModel> settings = new();

    protected override async Task OnInitializedAsync()
    {
        settings = await SettingService.GetSettingsAsync();
        await LoadLogos();
        await LoadPreview();
    }

    private async Task RefreshPreview()
    {
        await LoadPreview();
    }

    private async Task LoadPreview()
    {
        // var settings = await SettingService.GetSettingsAsync();

        previews.Clear();

        string[] docTypes = { "PR", "PO", "PN", "PS", "SC", "ICS", "PAR", "RIS"};

        foreach (var docType in docTypes)
        {
            previews[docType] =
                await SettingService.GeneratePreviewAsync(docType);
        }
    }

    private async Task ClearFormat(string docType)
    {
        previews[docType] = null;

        var setting = settings.FirstOrDefault(s => s.SettingDocumentType == docType);

        if (setting != null)
        {
            setting.SettingFormat = null;
            setting.SettingNumberSequence = 0;

            await SettingService.CreateSettingsAsync(setting);
        }

        await LoadPreview();
    }

    private async Task InsertToken(string docType, string token)
    {
        var setting = settings.FirstOrDefault(s => s.SettingDocumentType == docType);

        // CREATE setting if it does not exist
        if (setting == null)
        {
            setting = new SettingsModel
            {
                SettingDocumentType = docType,
                SettingFormat = "",
                SettingNumberSequence = 0,
                SettingIsEnable = false
            };

            settings.Add(setting);
        }

        string insertText = token switch
        {
            "YEAR" => "{YEAR}",
            "MONTH" => "{MM}",
            "SEQ" => docType switch
            {
                "PR" => "{SEQ:5}",
                "PO" => "{SEQ:5}",
                "PN" => "{SEQ:6}",
                "PS" => "{SEQ:6}",
                "SC" => "{SEQ:5}",
                "ICS" => "{SEQ:5}",
                "PAR" => "{SEQ:5}",
                "RIS" => "{SEQ:5}",
                _ => "{SEQ:5}"
            },
            _ => ""
        };

        if (string.IsNullOrEmpty(setting.SettingFormat))
            setting.SettingFormat = $"{docType}-" + insertText;
        else
            setting.SettingFormat += "-" + insertText;

        if (token == "SEQ")
        {
            setting.SettingIsEnable = true;
        }

        await SettingService.CreateSettingsAsync(setting);

        await LoadPreview();
    }

    private bool IsLocked(string docType)
    {
        var setting = settings.FirstOrDefault(s => s.SettingDocumentType == docType);
        return setting?.SettingIsEnable ?? false;
    }

    private async Task ToggleFormat(string docType)
    {
        var setting = settings.FirstOrDefault(s => s.SettingDocumentType == docType);

        if (setting != null)
        {
            setting.SettingIsEnable = !setting.SettingIsEnable;

            await SettingService.CreateSettingsAsync(setting);
            await LoadPreview();
        }
    }

    private string? DepEdLogoPreview;
    private string? DivisionLogoPreview;

    private IBrowserFile? DepEdFile;
    private IBrowserFile? DivisionFile;

    private async Task OnDepEdLogoSelected(InputFileChangeEventArgs e)
    {
        DepEdFile = e.File;

        using var stream = DepEdFile.OpenReadStream(5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        DepEdLogoPreview = $"data:{DepEdFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private async Task OnDivisionLogoSelected(InputFileChangeEventArgs e)
    {
        DivisionFile = e.File;

        using var stream = DivisionFile.OpenReadStream(5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        DivisionLogoPreview = $"data:{DivisionFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private async Task LoadLogos()
    {
        var depedLogo = await LogoService.GetLogoAsync("DEPED");
        if (depedLogo != null)
        {
            DepEdLogoPreview =
                $"data:{depedLogo.ContentType};base64,{Convert.ToBase64String(depedLogo.ImageData)}";
        }

        var divisionLogo = await LogoService.GetLogoAsync("DIVISION");
        if (divisionLogo != null)
        {
            DivisionLogoPreview =
                $"data:{divisionLogo.ContentType};base64,{Convert.ToBase64String(divisionLogo.ImageData)}";
        }
    }

    private async Task SaveDepEdLogo()
    {
        try
        {
            if (DepEdFile == null) return;

            using var ms = new MemoryStream();
            await DepEdFile.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);

            await LogoService.SaveLogoAsync("DEPED", ms.ToArray(), DepEdFile.ContentType);

            await LoadLogos();
        }
        catch(Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }

    private async Task SaveDivisionLogo()
    {
        if (DivisionFile == null) return;

        using var ms = new MemoryStream();
        await DivisionFile.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);

        await LogoService.SaveLogoAsync("DIVISION", ms.ToArray(), DivisionFile.ContentType);

        await LoadLogos();
    }

    private async Task RemoveDepEdLogo()
    {
        await LogoService.DeleteLogoAsync("DEPED");

        DepEdLogoPreview = null;
    }

    private async Task RemoveDivisionLogo()
    {
        await LogoService.DeleteLogoAsync("DIVISION");

        DivisionLogoPreview = null;
    }
    private string GetToggleColor(string documentType)
    {
        return documentType.ToLower() switch
        {
            "pr" or "po" => "peer-checked:bg-orange-500",
            "pn" or "ps" => "peer-checked:bg-green-500",
            "sc" or "ics" or "par" or "ris" => "peer-checked:bg-blue-500",
            "uacs" or "glsl" => "peer-checked:bg-orange-500",
            _ => "peer-checked:bg-blue-500"
        };
    }
} *@ 
