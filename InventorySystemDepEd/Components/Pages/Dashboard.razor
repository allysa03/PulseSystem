    //     }

    //     selectedNotification = null;

    //     recentActivities = await NotificationService
    //         .GetNotificationsByUserIdAsync(SessionData.CurrentUserId);

    //     StateHasChanged();
    // }

    private string GetNotificationTimeAgo(DateTime createdAt)
    {
        var ts = DateTime.UtcNow - createdAt.ToUniversalTime();

        if (ts.TotalSeconds < 60)
            return $"{(int)ts.TotalSeconds}s ago";

        if (ts.TotalMinutes < 60)
            return $"{(int)ts.TotalMinutes}m ago";

        if (ts.TotalHours < 24)
            return $"{(int)ts.TotalHours}h ago";

        if (ts.TotalDays < 7)
            return $"{(int)ts.TotalDays}d ago";

        return createdAt.ToString("MMM dd");
    }
}