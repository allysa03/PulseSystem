@page "/Account"
@inject HttpClient Http
@inject NavigationManager Navigation
@layout MainLayout

<PageTitle>Account - User Management</PageTitle>

<div class="p-6 bg-gray-100 min-h-screen">

    <!-- Header -->
    <div class="flex justify-between items-end pb-4 mb-5 border-b border-gray-200">
        <div>
            <h1 class="text-xl font-bold text-[rgb(5,39,103)] tracking-tight mb-0.5">Account Management</h1>
            <p class="text-xs text-gray-400">Manage and monitor user accounts</p>
        </div>

        <div class="flex items-center gap-3">
            <input type="text"
                   placeholder="Search users..."
                   class="border border-gray-300 rounded-lg px-4 py-2 text-xs focus:ring-2 focus:ring-[#052767] focus:outline-none"
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown" />
            <select @bind="statusFilter" class="border border-gray-300 rounded-lg px-4 py-2 text-xs focus:ring-2 focus:ring-[#052767] focus:outline-none">
                <option value="All">All Status</option>
                <option value="Pending">Pending</option>
                <option value="Declined">Declined</option>
                <option value="Active">Active</option>
                <option value="Deactivate">Inactive</option>
            </select>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-4 gap-3 mb-4">
        <div class="bg-white rounded-lg p-3 shadow-sm border border-gray-200 border-l-4 border-l-yellow-400 flex items-center gap-3">
            <div class="text-2xl text-yellow-400"><span class="bi bi-hourglass-split"></span></div>
            <div>
                <div class="text-xl font-bold text-[rgb(5,39,103)] leading-none mb-0.5">@GetStatusCount("Pending")</div>
                <div class="text-[10px] text-gray-600 font-semibold uppercase tracking-wider">Pending Approval</div>
            </div>
        </div>
        <div class="bg-white rounded-lg p-3 shadow-sm border border-gray-200 border-l-4 border-l-gray-400 flex items-center gap-3">
            <div class="text-2xl text-gray-400"><span class="bi bi-people-fill"></span></div>
            <div>
                <div class="text-xl font-bold text-[rgb(5,39,103)] leading-none mb-0.5">@GetStatusCount("Deactivate")</div>
                <div class="text-[10px] text-gray-600 font-semibold uppercase tracking-wider">Inactive Users</div>
            </div>
        </div>
        <div class="bg-white rounded-lg p-3 shadow-sm border border-gray-200 border-l-4 border-l-blue-500 flex items-center gap-3">
            <div class="text-2xl text-blue-500"><span class="bi bi-people-fill"></span></div>
            <div>
                <div class="text-xl font-bold text-[rgb(5,39,103)] leading-none mb-0.5">@GetStatusCount("Active")</div>
                <div class="text-[10px] text-gray-600 font-semibold uppercase tracking-wider">Active Users</div>
            </div>
        </div>
        <div class="bg-white rounded-lg p-3 shadow-sm border border-gray-200 border-l-4 border-l-red-500 flex items-center gap-3">
            <div class="text-2xl text-red-500"><span class="bi bi-x-circle-fill"></span></div>
            <div>
                <div class="text-xl font-bold text-[rgb(5,39,103)] leading-none mb-0.5">@GetStatusCount("Declined")</div>
                <div class="text-[10px] text-gray-600 font-semibold uppercase tracking-wider">Declined</div>
            </div>
        </div>
    </div>

    <!-- Loading / Empty States -->
    @if (isLoading)
    {
        <div class="flex flex-col items-center justify-center py-16">
            <div class="animate-spin h-12 w-12 border-b-2 border-[#052767] rounded-full"></div>
            <p class="mt-4 text-gray-500">Loading users...</p>
        </div>
    }
    else if (FilteredUsers().Count == 0)
    {
        <div class="bg-white rounded-xl shadow-sm border p-6">
            <h4 class="text-lg font-semibold text-gray-700">No Users Found</h4>
            <p class="text-gray-500 text-xs mt-1">There are currently no users in the system.</p>
        </div>
    }
    else
    {
        <!-- Table -->
        <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
            <table class="w-full text-xs">
                <thead>
                    <tr class="bg-gradient-to-r from-[rgb(5,39,103)] to-[rgb(3,30,80)] text-white">
                        <th class="px-4 py-3 text-left">User Details</th>
                        <th class="px-4 py-3 text-left">Email</th>
                        <th class="px-4 py-3 text-left">Role</th>
                        <th class="px-4 py-3 text-left">Status</th>
                        <th class="px-4 py-3 text-left">Registered Date</th>
                        <th class="px-4 py-3 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    @foreach (var user in PaginatedUsers())
                    {
                        <tr class="hover:bg-gray-100 transition cursor-pointer" @onclick="() => ViewUserDetails(user)">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-[#052767] to-[#031e50] text-white flex items-center justify-center font-bold text-xs">
                                        @GetInitials(user.FirstName, user.LastName)
                                    </div>
                                    <div class="font-semibold">@user.FirstName @user.LastName</div>
                                </div>
                            </td>
                            <td class="px-4 py-3">@user.EmailAddress</td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-0.5 bg-indigo-100 text-indigo-800 rounded text-[10px] font-medium">@(user.Role ?? "N/A")</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="status-badge @GetStatusClass(user.Status)">@user.Status</span>
                            </td>
                            <td class="px-4 py-3">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-3 text-center" @onclick:stopPropagation="true">
                                <div class="dropdown">
                                    <button class="action-btn dropdown-toggle" @onclick="() => ToggleDropdown(user.Id)">
                                        Actions <span class="bi @(IsDropdownOpen(user.Id) ? "bi-chevron-up" : "bi-chevron-down")"></span>
                                    </button>
                                    <div class="dropdown-menu @(IsDropdownOpen(user.Id) ? "show" : "") @(ShouldDropUp(PaginatedUsers().IndexOf(user), PaginatedUsers().Count) ? "dropup" : "")">

                                        @if (user.Status == "Pending")
                                        {
                                            <button class="dropdown-item" @onclick="async () => { await ApproveUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-check-circle"></span> Approve
                                            </button>
                                            <button class="dropdown-item" @onclick="async () => { await DeclineUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-x-circle"></span> Decline
                                            </button>
                                        }
                                        else if (user.Status == "Active")
                                        {
                                            <button class="dropdown-item" @onclick="async () => { await DeactivateUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-toggle-off"></span> Deactivate
                                            </button>
                                        }
                                        else if (user.Status == "Deactivate")
                                        {
                                            <button class="dropdown-item" @onclick="async () => { await ActivateUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-toggle-on"></span> Activate
                                            </button>
                                        }
                                        else if (user.Status == "Approved")
                                        {
                                            <button class="dropdown-item" @onclick="async () => { await DeactivateUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-toggle-off"></span> Deactivate
                                            </button>
                                            <button class="dropdown-item" @onclick="async () => { await ActivateUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-toggle-on"></span> Activate
                                            </button>
                                        }
                                        else if (user.Status == "Declined")
                                        {
                                            <button class="dropdown-item" @onclick="async () => { await ApproveUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-check-circle"></span> Approve
                                            </button>
                                            <button class="dropdown-item danger" @onclick="async () => { await RemoveUser(user.Id, user); CloseDropdown(); }">
                                                <span class="bi bi-trash"></span> Remove
                                            </button>
                                        }

                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination Component -->
            <Pagination TotalItems="FilteredUsers().Count"
                        ItemsLabel="Total Users"
                        ItemsPerPage="itemsPerPage"
                        CurrentPage="currentPage"
                        OnPageChanged="HandlePageChanged" />
        </div>
    }
</div>

<!-- User Details Modal -->
@if (showDetailsModal && selectedUser != null)
{
    <div class="fixed inset-0 z-[9999] flex items-center justify-center backdrop-blur-md"
         @onclick="CloseDetailsModal">

        <div class="bg-white/70 backdrop-blur-md rounded-xl shadow-2xl w-11/12 max-w-3xl max-h-[90vh] overflow-hidden flex flex-col border border-white/30"
             @onclick:stopPropagation>

            <!-- HEADER -->
            <div class="px-6 py-2 bg-gradient-to-r from-[#052767] to-[#031e50] flex justify-between items-center text-white rounded-t-xl">
                <h2 class="text-base font-semibold leading-none">
                    @selectedUser.FirstName @selectedUser.LastName
                </h2>
                <button class="text-lg font-semibold hover:text-gray-200 flex items-center justify-center leading-none w-6 h-6"
                        @onclick="CloseDetailsModal">
                    ✕
                </button>
            </div>

            <!-- BODY -->
            <div class="p-6 overflow-y-auto flex-1 space-y-6">

                <!-- USER QUICK INFO CARD -->
                <div class="bg-white/80 backdrop-blur-sm p-4 rounded-lg shadow-sm border border-white/30">
                    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
                        <div>
                            <span class="text-xs font-semibold text-gray-600 block uppercase mb-1">Email</span>
                            <p class="text-xs text-gray-800 font-medium">@selectedUser.EmailAddress</p>
                        </div>
                        <div>
                            <span class="text-xs font-semibold text-gray-600 block uppercase mb-1">Role</span>
                            <span class="px-2 py-0.5 bg-indigo-100 text-indigo-800 rounded text-[10px] font-medium inline-block">@(selectedUser.Role ?? "N/A")</span>
                        </div>
                        <div>
                            <span class="text-xs font-semibold text-gray-600 block uppercase mb-1">Status</span>
                            <span class="status-badge @GetStatusClass(selectedUser.Status)">@selectedUser.Status</span>
                        </div>
                        <div>
                            <span class="text-xs font-semibold text-gray-600 block uppercase mb-1">Registered</span>
                            <p class="text-xs text-gray-800 font-medium">@selectedUser.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

                <!-- ACCOUNT INFORMATION CARD -->
                <div class="bg-white/80 backdrop-blur-sm p-4 rounded-lg shadow-sm border border-white/30">
                    <h3 class="text-sm font-semibold text-gray-700 mb-3">Account Information</h3>

                    <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
                        <div>
                            <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">First Name</label>
                            <p class="text-xs text-gray-800 font-medium">@selectedUser.FirstName</p>
                        </div>

                        <div>
                            <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">Last Name</label>
                            <p class="text-xs text-gray-800 font-medium">@(selectedUser.LastName ?? "N/A")</p>
                        </div>

                        <div>
                            <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">Terms & Conditions</label>
                            <p class="text-xs">
                                @if (selectedUser.TermAndCon)
                                {
                                    <span class="text-green-600"><span class="bi bi-check-circle-fill"></span> Accepted</span>
                                }
                                else
                                {
                                    <span class="text-red-600"><span class="bi bi-x-circle-fill"></span> Not Accepted</span>
                                }
                            </p>
                        </div>

                        @if (selectedUser.IsApproved == true)
                        {
                            <div>
                                <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">Approved Date</label>
                                <p class="text-xs text-gray-800 font-medium">@(selectedUser.ApprovedAt.HasValue? selectedUser.ApprovedAt.Value.ToString("MMM dd, yyyy") : "N/A")</p>
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">Approved By</label>
                                <p class="text-xs text-gray-800 font-medium">@selectedUser.Approver</p>
                            </div>
                        }

                        @if (selectedUser.ModifiedAt.HasValue)
                        {
                            <div>
                                <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">Modified Date</label>
                                <p class="text-xs text-gray-800 font-medium">@selectedUser.ModifiedAt.Value.ToString("MMM dd, yyyy")</p>
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-gray-600 block uppercase mb-1">Modified By</label>
                                <p class="text-xs text-gray-800 font-medium">@selectedUser.ModifiedBy</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- FOOTER -->
            <div class="flex gap-2 justify-end mt-4 pt-3 border-t border-gray-200 flex-wrap px-6 py-4">
                @if (selectedUser.Status == "Pending")
                {
                    <button class="px-3 py-1.5 bg-green-600 text-white rounded text-xs font-semibold hover:bg-green-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await ApproveUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-check-circle"></span> Approve
                    </button>
                    <button class="px-3 py-1.5 bg-red-600 text-white rounded text-xs font-semibold hover:bg-red-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await DeclineUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-x-circle"></span> Decline
                    </button>
                }
                else if (selectedUser.Status == "Approved" || selectedUser.Status == "Inactive")
                {
                    <button class="px-3 py-1.5 bg-blue-600 text-white rounded text-xs font-semibold hover:bg-blue-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await ActivateUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-toggle-on"></span> Activate
                    </button>
                }
                else if (selectedUser.Status == "Declined")
                {
                    <button class="px-3 py-1.5 bg-green-600 text-white rounded text-xs font-semibold hover:bg-green-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await ApproveUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-check-circle"></span> Approve
                    </button>
                    <button class="px-3 py-1.5 bg-red-600 text-white rounded text-xs font-semibold hover:bg-red-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await RemoveUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-trash"></span> Remove
                    </button>
                }
                else if (selectedUser.Status == "Active")
                {
                    <button class="px-3 py-1.5 bg-yellow-600 text-white rounded text-xs font-semibold hover:bg-yellow-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await DeactivateUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-toggle-off"></span> Deactivate
                    </button>
                }
                else if (selectedUser.Status == "Deactivate")
                {
                    <button class="px-3 py-1.5 bg-blue-600 text-white rounded text-xs font-semibold hover:bg-blue-700 transition-all flex items-center gap-1"
                            @onclick="async () => { await ActivateUser(selectedUser.Id, selectedUser); }">
                        <span class="bi bi-toggle-on"></span> Activate
                    </button>
                }
                <button class="px-3 py-1.5 bg-blue-600 text-white rounded text-xs font-semibold hover:bg-blue-700 transition-all"
                        @onclick="CloseDetailsModal">
                    Close
                </button>
            </div>

        </div>
    </div>
}

<style>
    /* Status Badge Styles */
    .status-badge {
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.25px;
        display: inline-block;
        border: 1px solid;
        background: #ffffff;
    }

        .status-badge.pending {
            border-color: #d4a574;
            color: #7c5c3d;
        }

        .status-badge.deactivate {
            border-color: #b0b0b0;
            color: #6b7280;
        }

        .status-badge.active {
            border-color: #60a5fa;
            color: #1e40af;
        }

        .status-badge.declined {
            border-color: #f87171;
            color: #991b1b;
        }

        .status-badge.approved {
            border-color: #60a5fa;
            color: #1e40af;
        }

    /* Dropdown */
    .dropdown {
        position: relative;
        display: inline-block;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        right: 0;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        min-width: 120px;
        z-index: 1000;
        display: none;
        margin-top: 0.25rem;
    }

        .dropdown-menu.dropup {
            top: auto;
            bottom: 100%;
            margin-top: 0;
            margin-bottom: 0.25rem;
        }

        .dropdown-menu.show {
            display: block;
        }

    .dropdown-item {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: none;
        background: white;
        text-align: left;
        cursor: pointer;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #2c3e50;
        font-weight: 500;
    }

        .dropdown-item:hover {
            background-color: #f3f4f6;
        }

        .dropdown-item.danger {
            color: #ef4444;
        }

            .dropdown-item.danger:hover {
                background-color: #fee2e2;
            }

    .action-btn {
        background: none;
        border: none;
        color: rgb(5, 39, 103);
        cursor: pointer;
        font-size: 0.75rem;
        padding: 0.35rem 0.65rem;
        transition: all 0.2s ease;
        font-weight: 600;
        white-space: nowrap;
    }

        .action-btn:hover {
            color: rgb(3, 30, 80);
            text-decoration: underline;
        }

    .dropdown-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
    }
</style>

