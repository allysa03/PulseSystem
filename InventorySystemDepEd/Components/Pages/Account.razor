        {
            filtered = filtered.Where(u =>
                u.FirstName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (u.LastName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                u.EmailAddress.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (statusFilter != "All")
        {
            filtered = filtered.Where(u => u.Status == statusFilter);
        }

        return filtered.ToList();
    }

    private List<UserListDapper> PaginatedUsers()
    {
        return FilteredUsers()
            .Skip((currentPage - 1) * itemsPerPage)
            .Take(itemsPerPage)
            .ToList();
    }

    private int GetStatusCount(string status)
    {
        return users.Count(u => u.Status == status);
    }

    private string GetInitials(string firstName, string? lastName)
    {
        var initials = firstName.Substring(0, 1).ToUpper() ?? "N";
        if (!string.IsNullOrWhiteSpace(lastName))
        {
            initials += lastName.Substring(0, 1).ToUpper() ?? "A";
        }
        return initials;
    }

    private string GetStatusClass(string status)
    {
        return status.ToLower();
    }

    private void ViewUserDetails(UserListDapper user)
    {
        selectedUser = user;
        showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedUser = null;
    }

    private void ToggleDropdown(int userId)
    {
        openDropdownId = openDropdownId == userId ? null : userId;
    }

    private bool IsDropdownOpen(int userId)
    {
        return openDropdownId == userId;
    }

    private void CloseDropdown()
    {
        openDropdownId = null;
    }

    private bool ShouldDropUp(int index, int totalCount)
    {
        return totalCount - index <= 1;
    }

    private async Task ApproveUser(int userID, UserListDapper user)
    {
        await Task.Delay(300);
        user.Status = "Active";
        user.IsApproved = true;
        user.ApprovedAt = DateTime.Now;
        user.Approver = "Current Admin";
        StateHasChanged();
        if (showDetailsModal)
            CloseDetailsModal();
    }

    private async Task DeclineUser(int userID, UserListDapper user)
    {
        await Task.Delay(300);
        user.Status = "Declined";
        StateHasChanged();
        if (showDetailsModal)
            CloseDetailsModal();
    }

    private async Task ActivateUser(int userID, UserListDapper user)
    {
        await Task.Delay(300);
        user.Status = "Active";
        StateHasChanged();
        if (showDetailsModal)
            CloseDetailsModal();
    }

    private async Task DeactivateUser(int userID, UserListDapper user)
    {
        await Task.Delay(300);
        user.Status = "Deactivate";
        user.ModifiedAt = DateTime.Now;
        user.ModifiedBy = "Current Admin";
        StateHasChanged();
        if (showDetailsModal)
            CloseDetailsModal();
    }

    private async Task RemoveUser(int userID, UserListDapper user)
    {
        await Task.Delay(300);
        users.Remove(user);
        StateHasChanged();
        if (showDetailsModal)
            CloseDetailsModal();
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            searchQuery = "";
    }

    private void HandlePageChanged(int page)
    {
        currentPage = page;
    }

    // Model class - matches tbl_users with joins for full names
    public class UserListDapper
    {
        public int Id { get; set; }                          // user_id
        public string FirstName { get; set; } = string.Empty;  // From Personnel
        public string? LastName { get; set; }                  // From Personnel
        public string EmailAddress { get; set; } = string.Empty;  // user_emailAddress
        public string Role { get; set; } = string.Empty;      // Role name
        public string Status { get; set; } = string.Empty;    // user_status
        public DateTime CreatedAt { get; set; }               // user_createdAt
        public bool TermAndCon { get; set; }                  // user_termAndCon
        public bool? IsApproved { get; set; }                 // user_IsApproved
        public DateTime? ApprovedAt { get; set; }             // user_approvedAt
        public string? Approver { get; set; }                 // Approver name
        public DateTime? ModifiedAt { get; set; }             // user_modifiedAt
        public string? ModifiedBy { get; set; }               // Modifier name
    }
}
